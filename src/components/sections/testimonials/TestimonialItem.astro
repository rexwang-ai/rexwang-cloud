---
import { Image } from 'astro:assets';
import Icon from '../../ui/icons/Icon.astro';

const { content, author, role, avatarSrc } = Astro.props;

interface Props {
  content: string;
  author: string;
  role: string;
  avatarSrc: string;
}
---

<blockquote class="relative pl-8">
  <div class="absolute left-0 top-0 opacity-30">
    <Icon name="quotation" />
  </div>

  <div class="relative z-10">
    <p class="text-xl text-neutral-800 italic dark:text-neutral-200">
      {content}
    </p>
  </div>

  <div class="mt-6">
    <div class="flex items-center">
      <div class="shrink-0">
        {avatarSrc ? (
          <Image
            class="h-8 w-8 rounded-full"
            src={avatarSrc}
            alt="Avatar Description"
            loading={'eager'}
            inferSize
          />
        ) : (
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-orange-400 to-yellow-400 text-xs font-bold text-white">
            {author.charAt(0)}
          </div>
        )}
      </div>
      <div class="ms-4 grow">
        <div class="font-bold text-neutral-900 dark:text-white">
          {author}
        </div>
        <div class="text-xs text-neutral-600 dark:text-neutral-300">{role}</div>
      </div>
    </div>
  </div>
</blockquote>
