---
import { Image } from 'astro:assets';
import Icon from '../../ui/icons/Icon.astro';

const { content, author, role, avatarSrc } = Astro.props;

interface Props {
  content: string;
  author: string;
  role: string;
  avatarSrc: string;
}
---

<blockquote class="relative">
  {/* Name and Avatar at the top */}
  <div class="flex items-center mb-4">
    <div class="shrink-0">
      {avatarSrc ? (
        <Image
          class="h-10 w-10 rounded-full"
          src={avatarSrc}
          alt="Avatar Description"
          loading={'eager'}
          inferSize
        />
      ) : (
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-orange-400 to-yellow-400 text-sm font-bold text-white">
          {author.charAt(0)}
        </div>
      )}
    </div>
    <div class="ms-3">
      <div class="font-bold text-neutral-900 dark:text-white">
        {author}
      </div>
      <div class="text-xs text-neutral-600 dark:text-neutral-300">{role}</div>
    </div>
  </div>

  {/* Content */}
  <div class="relative z-10">
    <p class="text-lg text-neutral-700 italic dark:text-neutral-300 leading-relaxed">
      {content}
    </p>
  </div>
</blockquote>
