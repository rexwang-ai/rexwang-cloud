---
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';

const pageTitle = `产品与服务 | ${SITE.title}`;
---

<MainLayout title={pageTitle}>
  <!-- Hero -->
  <section class="mx-auto max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-neutral-800 md:text-5xl dark:text-neutral-200">
        产品与服务<span class="text-yellow-500 dark:text-yellow-400">体系</span>
      </h1>
      <p class="mt-4 text-lg text-neutral-600 dark:text-neutral-400">
        从认知升级到系统落地，找到适合你的路径
      </p>
    </div>
  </section>

  <!-- 课程培训 -->
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8">
    <div class="rounded-xl border border-neutral-200 bg-white p-8 shadow-sm dark:border-neutral-700 dark:bg-neutral-800 lg:p-10">
      <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
        <div>
          <h2 class="text-2xl font-bold text-neutral-800 dark:text-neutral-100">课程培训</h2>
          <p class="mt-2 text-neutral-600 dark:text-neutral-400">从入门到精通的学习路径，系统掌握老板AI化方法论</p>
        </div>
        <div class="space-y-4">
          <div class="flex items-baseline justify-between border-b border-dashed border-neutral-200 pb-3 dark:border-neutral-600">
            <div>
              <div class="font-bold text-neutral-800 dark:text-neutral-100">引流体验课</div>
              <div class="text-sm text-neutral-500 dark:text-neutral-400">快速了解老板AI化核心框架</div>
            </div>
            <span class="font-bold text-lg text-neutral-800 dark:text-neutral-100">¥19.9</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-dashed border-neutral-200 pb-3 dark:border-neutral-600">
            <div>
              <div class="font-bold text-neutral-800 dark:text-neutral-100">线上系统课</div>
              <div class="text-sm text-neutral-500 dark:text-neutral-400">完整方法论 + 实操案例</div>
            </div>
            <span class="font-bold text-lg text-neutral-800 dark:text-neutral-100">¥2,980</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-dashed border-neutral-200 pb-3 dark:border-neutral-600">
            <div>
              <div class="font-bold text-neutral-800 dark:text-neutral-100">线下实战营</div>
              <div class="text-sm text-neutral-500 dark:text-neutral-400">面对面深度训练，现场出方案</div>
            </div>
            <span class="font-bold text-lg text-neutral-800 dark:text-neutral-100">¥39,800</span>
          </div>
          <div class="flex items-baseline justify-between">
            <div>
              <div class="font-bold text-neutral-800 dark:text-neutral-100">1对1私教</div>
              <div class="text-sm text-neutral-500 dark:text-neutral-400">针对性辅导，加速落地</div>
            </div>
            <span class="font-bold text-lg text-indigo-600 dark:text-indigo-400">¥98,000</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 老板在线 -->
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-xl bg-gradient-to-tr from-[#FF512F] to-[#F09819] p-8 shadow-xl lg:p-10">
      <div class="absolute -top-3 right-6 rounded-full bg-white px-4 py-1 text-sm font-bold text-orange-600 shadow">推荐</div>
      <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
        <div>
          <h2 class="text-2xl font-bold text-white">老板在线</h2>
          <p class="mt-2 text-orange-100">24小时AI数字分身，你的在线商业顾问</p>
          <p class="mt-4 text-sm text-orange-100/80 leading-relaxed">
            声音克隆 + 黄金圈内容 + AI Bot交互 = 老板24h数字分身<br />
            围绕老板建站，不是围绕公司建站。让你的认知和经验，24小时在线服务客户。
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex items-baseline justify-between border-b border-dashed border-orange-300/40 pb-3">
            <div>
              <div class="font-bold text-white">基础版</div>
              <div class="text-sm text-orange-100">AI Bot + 品牌内容</div>
            </div>
            <span class="font-bold text-lg text-white">¥39,800</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-dashed border-orange-300/40 pb-3">
            <div>
              <div class="font-bold text-white">专业版</div>
              <div class="text-sm text-orange-100">+ 声音克隆 + 全平台分发</div>
            </div>
            <span class="font-bold text-lg text-white">¥68,000</span>
          </div>
          <div class="flex items-baseline justify-between">
            <div>
              <div class="font-bold text-white">旗舰版</div>
              <div class="text-sm text-orange-100">+ 全链路商业闭环</div>
            </div>
            <span class="font-bold text-lg text-yellow-200">¥128,000</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 项目全案 -->
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8">
    <div class="rounded-xl border border-neutral-200 bg-white p-8 shadow-sm dark:border-neutral-700 dark:bg-neutral-800 lg:p-10">
      <div class="grid gap-8 lg:grid-cols-2 lg:items-start">
        <div>
          <h2 class="text-2xl font-bold text-neutral-800 dark:text-neutral-100">项目全案</h2>
          <p class="mt-2 text-neutral-600 dark:text-neutral-400">定制化AI商业落地方案</p>
          <p class="mt-4 text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">
            只输出策划方案，不代运营。轻交付，模块化搭建。<br />
            从顶层架构设计到AI产品开发，从内容全平台分发到商业变现，跑通完整闭环。
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex items-baseline justify-between border-b border-dashed border-neutral-200 pb-3 dark:border-neutral-600">
            <div>
              <div class="font-bold text-neutral-800 dark:text-neutral-100">标准全案</div>
              <div class="text-sm text-neutral-500 dark:text-neutral-400">定位升级 + AI化基础架构</div>
            </div>
            <span class="font-bold text-lg text-neutral-800 dark:text-neutral-100">¥168,000</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-dashed border-neutral-200 pb-3 dark:border-neutral-600">
            <div>
              <div class="font-bold text-neutral-800 dark:text-neutral-100">深度全案</div>
              <div class="text-sm text-neutral-500 dark:text-neutral-400">+ 智能体集群 + 内容飞轮</div>
            </div>
            <span class="font-bold text-lg text-neutral-800 dark:text-neutral-100">¥238,000</span>
          </div>
          <div class="flex items-baseline justify-between">
            <div>
              <div class="font-bold text-neutral-800 dark:text-neutral-100">战略全案</div>
              <div class="text-sm text-neutral-500 dark:text-neutral-400">+ 全域商业闭环</div>
            </div>
            <span class="font-bold text-lg text-indigo-600 dark:text-indigo-400">¥360,000</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-neutral-800 md:text-3xl dark:text-neutral-200">
        先改变老板，才能改变企业
      </h2>
      <p class="mt-3 text-neutral-600 dark:text-neutral-400">
        使命：带领10万+企业老板走进AI世界，用「定位升级 + 老板AI化」跳出同质化内卷，打造极简组织，实现幸福感创业。
      </p>
      <div class="mt-8">
        <a href="/about" class="inline-flex items-center rounded-lg bg-orange-500 px-8 py-3 text-base font-bold text-white transition hover:bg-orange-600">
          了解 Rex Wang
          <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</MainLayout>
