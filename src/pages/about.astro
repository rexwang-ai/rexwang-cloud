---
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';

const pageTitle = `认识我 | ${SITE.title}`;
---

<MainLayout title={pageTitle}>
  <!-- ====== Hero: 左文右图 ====== -->
  <section class="mx-auto max-w-[85rem] px-4 pt-14 pb-10 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-16">
      <!-- 左侧：文字 -->
      <div class="flex-1">
        <h1 class="text-4xl font-bold tracking-tight text-neutral-800 md:text-5xl dark:text-neutral-200">
          王鹏辉
        </h1>
        <p class="mt-1 text-xl text-neutral-500 dark:text-neutral-400">Rex Wang</p>
        <ul class="mt-5 space-y-2 text-base leading-relaxed text-neutral-700 dark:text-neutral-300">
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-500"></span>
            同济EMBA特聘导师
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-500"></span>
            品牌定位战略顾问 × AI 商业顾问
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-500"></span>
            全球老板AI化课题发起人 &amp; 首席研究员
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-yellow-500"></span>
            <strong class="text-yellow-600 dark:text-yellow-400">老板AI化·高维盈利体系创始人</strong>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-500"></span>
            实战派老师，18年品牌定位授课超1000场
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-500"></span>
            AI化实战导师，AI商业架构师，AI产品开发者
          </li>
        </ul>
      </div>
      <!-- 右侧：照片 -->
      <div class="flex-shrink-0 lg:w-[420px]">
        <img
          src="/images/events/huichang02.jpg"
          alt="老板AI化实战营课程现场"
          class="w-full rounded-2xl object-cover shadow-lg"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- ====== 核心论断 ====== -->
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold text-neutral-800 dark:text-neutral-200">
        独家核心论断
      </h2>
      <div class="mt-6 space-y-5">
        <div class="flex items-start gap-3">
          <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-yellow-500 text-xs font-bold text-white">▸</span>
          <p class="text-lg leading-relaxed text-neutral-700 dark:text-neutral-300">
            <strong>先改变老板，才能改变企业</strong>；老板脱胎换骨，企业才能脱胎换骨
          </p>
        </div>
        <div class="flex items-start gap-3">
          <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-yellow-500 text-xs font-bold text-white">▸</span>
          <p class="text-lg leading-relaxed text-neutral-700 dark:text-neutral-300">
            <strong>老板是发动机，定位是方向盘，AI是放大器</strong>
          </p>
        </div>
        <div class="flex items-start gap-3">
          <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-yellow-500 text-xs font-bold text-white">▸</span>
          <p class="text-lg leading-relaxed text-neutral-700 dark:text-neutral-300">
            <strong>碳基智慧 × 硅基执行力 = AI核聚变</strong>，AI是让你脱胎换骨的引擎
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== 双维实战背景 + 课程现场 ====== -->
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-3">
      <!-- 左列：两张背景卡片 -->
      <div class="space-y-6 lg:col-span-2">
        <div class="rounded-xl border border-neutral-200 bg-white p-8 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
          <h2 class="text-xl font-bold text-neutral-800 dark:text-neutral-100">
            ■ 18年实体经营深耕 · 懂商业本质
          </h2>
          <ul class="mt-4 space-y-3 text-neutral-700 dark:text-neutral-300">
            <li class="flex items-start gap-2">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-500"></span>
              深圳赢想力品牌管理有限公司创始人
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-500"></span>
              同济EMBA玄奘商途全维增长导师
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-500"></span>
              连续创业者，深耕品牌定位咨询与企业增长培训18年，累计服务上千家中小企业
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-orange-500"></span>
              2015年出版著作《跨界人生》
            </li>
          </ul>
        </div>

        <div class="rounded-xl border border-neutral-200 bg-white p-8 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
          <h2 class="text-xl font-bold text-neutral-800 dark:text-neutral-100">
            ■ AI全链路实战能力 · 懂落地方法
          </h2>
          <ul class="mt-4 space-y-3 text-neutral-700 dark:text-neutral-300">
            <li class="flex items-start gap-2">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-indigo-500"></span>
              AI商业架构师 / AI产品开发者 / 老板AI化导师
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-indigo-500"></span>
              国内少有的"既懂传统企业经营本质，又懂AI智能商业落地"的实战派导师
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-indigo-500"></span>
              独创"短链商业 × 智能体集群 × AI自进化"的AI创业三元论，率先提出"中小企业AI转型的核心，是老板AI化"的行业论断
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-indigo-500"></span>
              一人跑通"顶层架构设计→AI产品开发→内容全平台分发→商业变现"完整闭环
            </li>
          </ul>
        </div>
      </div>

      <!-- 右列：课程现场照片 -->
      <div class="flex items-center justify-center">
        <div class="sticky top-24 w-full overflow-hidden rounded-2xl shadow-lg">
          <img
            src="/images/events/huichang05.jpg"
            alt="老板AI化实战营课程现场"
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ====== 实证标杆：转型对比 ====== -->
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-bold text-neutral-800 dark:text-neutral-200">
        实证标杆：自己就是老板AI化的最佳案例
      </h2>
      <div class="mt-6 overflow-hidden rounded-xl border border-neutral-200 dark:border-neutral-700">
        <div class="grid grid-cols-1 md:grid-cols-3">
          <!-- 转型前 -->
          <div class="bg-neutral-50 p-6 dark:bg-neutral-800/50">
            <div class="mb-3 text-xs font-bold uppercase tracking-wider text-neutral-500">AI化转型前</div>
            <p class="text-neutral-700 dark:text-neutral-300">
              传统品牌咨询公司创始人，核心能力聚焦定位咨询与课程交付，业务边界清晰单一
            </p>
          </div>
          <!-- 箭头 -->
          <div class="flex items-center justify-center bg-gradient-to-br from-[#FF512F] to-[#F09819] p-6 text-center">
            <div>
              <div class="text-lg font-bold text-white">核聚变式升级</div>
              <div class="mt-1 text-sm text-orange-100">→</div>
            </div>
          </div>
          <!-- 转型后 -->
          <div class="bg-neutral-50 p-6 dark:bg-neutral-800/50">
            <div class="mb-3 text-xs font-bold uppercase tracking-wider text-orange-600">AI化转型后</div>
            <p class="text-sm leading-relaxed text-neutral-700 dark:text-neutral-300">
              融合18年定位积累+AI能力，全面打破能力与业务边界：
            </p>
            <ul class="mt-3 space-y-2 text-sm text-neutral-600 dark:text-neutral-400">
              <li>• 独立开发行业专属AI模型，打造老板AI化落地工具体系</li>
              <li>• 全平台持续内容输出，快速建立行业影响力</li>
              <li>• 跨领域多线推进项目，一人完成过去一个团队的工作量</li>
              <li>• 公司从单一品牌咨询机构，升级为AI商业科技公司</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== 底部使命 ====== -->
  <section class="mx-auto max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-neutral-800 md:text-3xl dark:text-neutral-200">
        核心使命
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
        带领10万+企业老板走进AI世界，用「定位升级 + 老板AI化」跳出同质化内卷，打造极简组织，实现幸福感创业。
      </p>
      <div class="mt-8 flex justify-center gap-4">
        <a href="/products" class="inline-flex items-center rounded-lg bg-orange-500 px-8 py-3 text-base font-bold text-white transition hover:bg-orange-600">
          查看产品体系
          <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
        <a href="/" class="inline-flex items-center rounded-lg border border-neutral-300 px-8 py-3 text-base font-bold text-neutral-700 transition hover:bg-neutral-100 dark:border-neutral-600 dark:text-neutral-200 dark:hover:bg-neutral-700">
          返回首页
        </a>
      </div>
    </div>
  </section>
</MainLayout>
