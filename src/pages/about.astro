---
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';

const pageTitle = `关于 | ${SITE.title}`;
---

<MainLayout title={pageTitle}>
  <section class="mx-auto max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-4xl font-bold tracking-tight text-neutral-800 md:text-5xl dark:text-neutral-200">
        关于 Rex Wang
      </h1>
      <p class="mt-4 text-lg text-neutral-600 dark:text-neutral-400">
        18年品牌定位战略顾问 × AI商业全链路操盘手
      </p>

      <div class="mt-8 space-y-6 text-neutral-700 dark:text-neutral-300">
        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-neutral-800">
          <h2 class="text-2xl font-bold text-neutral-800 dark:text-neutral-200">
            🎯 我是谁
          </h2>
          <p class="mt-3 leading-relaxed">
            我叫王鹏辉（Rex Wang），拥有18年品牌定位咨询经验。我相信「先改变老板，才能改变企业」——AI化的核心不是工具，而是老板的认知升级。
          </p>
          <p class="mt-3 leading-relaxed">
            我创立了「老板AI化·高维盈利体系」，帮助企业家用AI构建第二大脑，让AI成为放大器而非替代品。
          </p>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-neutral-800">
          <h2 class="text-2xl font-bold text-neutral-800 dark:text-neutral-200">
            💡 核心理念
          </h2>
          <ul class="mt-3 space-y-2 leading-relaxed">
            <li>• <strong>AI是放大器，老板才是发动机</strong> — AI不替代决策，而是增强决策者的能力</li>
            <li>• <strong>先改变老板，再改变企业</strong> — 认知升级先于工具落地</li>
            <li>• <strong>不做别人已经在做的事</strong> — 专注定义全新品类</li>
            <li>• <strong>短链商业 × AI智能体集群</strong> — 最小化中间环节，最大化价值传递</li>
          </ul>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-neutral-800">
          <h2 class="text-2xl font-bold text-neutral-800 dark:text-neutral-200">
            📸 现场风采
          </h2>
          <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3">
            <img src="/images/events/huichang01.jpg" alt="会场实拍1" class="rounded-lg object-cover aspect-square" />
            <img src="/images/events/huichang02.jpg" alt="会场实拍2" class="rounded-lg object-cover aspect-square" />
            <img src="/images/events/huichang03.jpg" alt="会场实拍3" class="rounded-lg object-cover aspect-square" />
            <img src="/images/events/huichang04.jpg" alt="会场实拍4" class="rounded-lg object-cover aspect-square" />
            <img src="/images/events/huichang05.jpg" alt="会场实拍5" class="rounded-lg object-cover aspect-square" />
          </div>
        </div>

        <div class="rounded-xl bg-white p-6 shadow-sm dark:bg-neutral-800">
          <h2 class="text-2xl font-bold text-neutral-800 dark:text-neutral-200">
            🔗 联系方式
          </h2>
          <div class="mt-3 space-y-2">
            <p>
              <strong>GitHub：</strong>
              <a href="https://github.com/rexwang-ai" target="_blank" rel="noopener noreferrer" class="text-yellow-600 underline dark:text-yellow-400">
                github.com/rexwang-ai
              </a>
            </p>
            <p>
              <strong>X (Twitter)：</strong>
              <a href="https://x.com/rexwang_ai" target="_blank" rel="noopener noreferrer" class="text-yellow-600 underline dark:text-yellow-400">
                @rexwang_ai
              </a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
