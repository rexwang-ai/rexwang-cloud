---
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro';
import FAQ from '@components/sections/misc/FAQ.astro';
import Icon from '@components/ui/icons/Icon.astro';
import { SITE } from '@data/constants';
import features from '@data_files/features.json';
import faqsData from '@data_files/faqs.json';

const pageTitle = `${SITE.title} — 老板AI化`;

const testimonials = [
  {
    content: '以前觉得AI跟我这种传统行业老板没关系，上完Rex的课才发现，AI化的第一步真的是换脑子。现在我一个人管着3条业务线，效率比过去一个团队还高。',
    author: '陈总',
    role: '某建材连锁品牌 创始人',
    avatarSrc: '',
  },
  {
    content: '做了15年品牌咨询，换过好几家咨询公司，都是给你一堆PPT自己落地。Rex不一样，他帮你把AI能力直接嵌进执行链路，系统搭好了自己跑。',
    author: '范总',
    role: '某科技企业 CEO',
    avatarSrc: '',
  },
  {
    content: '「先改变老板，才能改变企业」这句话打动了我。上完课我才意识到，过去3年踩的坑全是认知问题。现在公司人少了，利润反而翻倍了。',
    author: '林总',
    role: '某消费品品牌 董事长',
    avatarSrc: '',
  },
];

const statistics = [
  { count: '18年', description: '品牌定位咨询实战经验' },
  { count: '1000+', description: '场定位培训授课经历' },
  { count: '1000+', description: '家中小企业服务案例' },
  { count: '10万+', description: '企业老板AI化目标覆盖' },
];
---

<MainLayout title={pageTitle}>
  <!-- 1. Hero Section -->
  <HeroSection
    title={`<span class="text-sm font-semibold uppercase tracking-wider text-indigo-600 dark:text-indigo-400">老板AI化</span><br />锻造老板<span class="text-yellow-500 dark:text-yellow-400">第二大脑</span><br /><span class="text-lg sm:text-xl font-medium text-neutral-600 dark:text-neutral-300">打造极简组织，实现高维盈利</span>`}
    subTitle={`老板是发动机，定位是方向盘，AI是放大器。<br /><br /><strong>Rex Wang</strong>，全球老板AI化课题发起人 & 首席研究员<br />老板AI化·高维盈利体系创始人<br />18年品牌定位培训咨询经验，帮你用AI构建高维盈利体系。`}
    primaryBtn="了解更多"
    primaryBtnURL="/about"
    secondaryBtn="阅读博客"
    secondaryBtnURL="/blog"
    withReview={false}
    src="/images/profile/rex1024.png"
    alt="Rex Wang - 王鹏辉"
  />

  <!-- 2. Features - 核心方法论 -->
  <FeaturesGeneral
    title="老板AI化·<span class='text-yellow-500 dark:text-yellow-400'>高维盈利体系</span>"
    subTitle="不是教你用AI工具，而是帮你建立AI时代的商业操作系统。"
    features={features}
  />

  <!-- 3. Testimonials - 客户评价 -->
  <TestimonialsSection
    title="老板们的<span class='text-yellow-500 dark:text-yellow-400'>真实反馈</span>"
    subTitle="先改变老板，才能改变企业。听听已经走过这一步的老板怎么说。"
    testimonials={testimonials}
    statistics={statistics}
  />

  <!-- 4. Pricing - 产品体系 -->
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full">
    <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
      <h2 class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200">
        产品与服务<span class="text-yellow-500 dark:text-yellow-400">体系</span>
      </h2>
      <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
        从认知升级到系统落地，找到适合你的路径
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3 lg:gap-8">
      <!-- 课程培训 -->
      <div class="rounded-xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
        <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-100">课程培训</h3>
        <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">从入门到精通的学习路径</p>
        <div class="mt-4 space-y-3">
          <div class="flex items-baseline justify-between border-b border-dashed border-neutral-200 pb-2 dark:border-neutral-600">
            <span class="text-sm text-neutral-600 dark:text-neutral-300">引流体验课</span>
            <span class="font-bold text-neutral-800 dark:text-neutral-100">¥19.9</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-dashed border-neutral-200 pb-2 dark:border-neutral-600">
            <span class="text-sm text-neutral-600 dark:text-neutral-300">线上系统课</span>
            <span class="font-bold text-neutral-800 dark:text-neutral-100">¥2,980</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-dashed border-neutral-200 pb-2 dark:border-neutral-600">
            <span class="text-sm text-neutral-600 dark:text-neutral-300">线下实战营</span>
            <span class="font-bold text-neutral-800 dark:text-neutral-100">¥39,800</span>
          </div>
          <div class="flex items-baseline justify-between">
            <span class="text-sm text-neutral-600 dark:text-neutral-300">1对1私教</span>
            <span class="font-bold text-lg text-indigo-600 dark:text-indigo-400">¥98,000</span>
          </div>
        </div>
        <a href="#contact" class="mt-6 block rounded-lg bg-neutral-100 px-6 py-2.5 text-center text-sm font-bold text-neutral-700 transition hover:bg-neutral-200 dark:bg-neutral-700 dark:text-neutral-200 dark:hover:bg-neutral-600">了解详情</a>
      </div>

      <!-- 老板在线 (推荐) -->
      <div class="relative rounded-xl bg-linear-to-tr from-[#FF512F] to-[#F09819] p-6 shadow-xl">
        <div class="absolute -top-3 right-4 rounded-full bg-white px-3 py-1 text-xs font-bold text-orange-600 shadow">推荐</div>
        <h3 class="text-xl font-bold text-white">老板在线</h3>
        <p class="mt-1 text-sm text-orange-100">24小时AI数字分身，你的在线商业顾问</p>
        <div class="mt-4 space-y-3">
          <div class="flex items-baseline justify-between border-b border-dashed border-orange-300/40 pb-2">
            <span class="text-sm text-orange-100">基础版</span>
            <span class="font-bold text-white">¥39,800</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-dashed border-orange-300/40 pb-2">
            <span class="text-sm text-orange-100">专业版</span>
            <span class="font-bold text-white">¥68,000</span>
          </div>
          <div class="flex items-baseline justify-between">
            <span class="text-sm text-orange-100">旗舰版</span>
            <span class="font-bold text-lg text-yellow-200">¥128,000</span>
          </div>
        </div>
        <p class="mt-3 text-xs text-orange-100/80">声音克隆 + 黄金圈内容 + AI Bot交互 = 老板24h数字分身</p>
        <a href="#contact" class="mt-4 block rounded-lg bg-white px-6 py-2.5 text-center text-sm font-bold text-orange-600 transition hover:bg-orange-50">了解详情</a>
      </div>

      <!-- 项目全案 -->
      <div class="rounded-xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
        <h3 class="text-xl font-bold text-neutral-800 dark:text-neutral-100">项目全案</h3>
        <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">定制化AI商业落地方案</p>
        <div class="mt-4 space-y-3">
          <div class="flex items-baseline justify-between border-b border-dashed border-neutral-200 pb-2 dark:border-neutral-600">
            <span class="text-sm text-neutral-600 dark:text-neutral-300">标准全案</span>
            <span class="font-bold text-neutral-800 dark:text-neutral-100">¥168,000</span>
          </div>
          <div class="flex items-baseline justify-between border-b border-dashed border-neutral-200 pb-2 dark:border-neutral-600">
            <span class="text-sm text-neutral-600 dark:text-neutral-300">深度全案</span>
            <span class="font-bold text-neutral-800 dark:text-neutral-100">¥238,000</span>
          </div>
          <div class="flex items-baseline justify-between">
            <span class="text-sm text-neutral-600 dark:text-neutral-300">战略全案</span>
            <span class="font-bold text-lg text-indigo-600 dark:text-indigo-400">¥360,000</span>
          </div>
        </div>
        <p class="mt-3 text-xs text-neutral-500 dark:text-neutral-400">只输出策划方案，不代运营。轻交付，模块化搭建。</p>
        <a href="#contact" class="mt-4 block rounded-lg bg-neutral-800 px-6 py-2.5 text-center text-sm font-bold text-white transition hover:bg-neutral-700 dark:bg-neutral-600 dark:hover:bg-neutral-500">预约咨询</a>
      </div>
    </div>
  </section>

  <!-- 5. FAQ -->
  <FAQ title="常见<span class='text-yellow-500 dark:text-yellow-400'>问题</span>" faqs={faqsData.faqs} />

  <!-- 6. Bottom CTA -->
  <HeroSectionAlt
    title="先改变老板，才能改变企业"
    subTitle="使命：带领10万+企业老板走进AI世界，用「定位升级 + 老板AI化」跳出同质化内卷，打造极简组织，实现幸福感创业。"
  />
</MainLayout>
