---
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro';
import FAQ from '@components/sections/misc/FAQ.astro';
import Icon from '@components/ui/icons/Icon.astro';
import { SITE } from '@data/constants';
import features from '@data/features.json';
import faqsData from '@data/faqs.json';

const pageTitle = `${SITE.title} — 老板AI化`;

const testimonials = [
  {
    content: '合作过一些咨询公司，都是给你一堆PPT自己落地。Rex不一样，他帮你把AI能力直接嵌进执行链路，系统搭好了自己跑。特别是嵌入我们老板的决策中，打开了思路，效果非常好。',
    author: '秦总',
    role: '某科技企业 CEO',
    avatarSrc: '',
  },
  {
    content: '以前觉得AI跟我这种传统行业老板没关系，上完Rex的课才发现，AI化的第一步真的是换脑子。现在我一个人管着3条业务线，效率比过去一个团队还高。',
    author: '林总',
    role: '某建材连锁品牌 创始人',
    avatarSrc: '',
  },
  {
    content: '过去3年公司越做越重，团队30多人还是亏损。上完课后我把80%的重复工作交给了AI，现在13个人的公司利润翻了1倍。Rex让我明白，不是人不够，是认知没到位。',
    author: '黄总',
    role: '某消费品品牌 董事长',
    avatarSrc: '',
  },
];

const statistics = [
  { count: '18年', description: '品牌定位咨询实战经验' },
  { count: '1000+场', description: '定位培训授课经历' },
  { count: '1000+家', description: '中小企业服务案例' },
  { count: '10万+', description: '未来实现企业老板AI化目标覆盖' },
];
---

<MainLayout title={pageTitle}>
  <!-- 1. Hero Section (without buttons) -->
  <HeroSection
    title={`Hi There & Welcome to My Corner of the Web!<br /><span class="text-2xl sm:text-3xl lg:text-4xl text-neutral-600 dark:text-neutral-400">你好，欢迎来到我的线上一隅！</span>`}
    subTitle={`<strong>我是 Rex Wang</strong>，同济 EMBA 特聘导师 / 品牌定位战略顾问 × AI 商业顾问。<br />全球老板 AI 化课题发起人 & 首席研究员，老板 AI 化・高维盈利体系创建者。<br /><br />深耕品牌定位咨询与实体经营 <strong>18 年</strong>，授课超 <strong>1000 场</strong>，服务中小企业 <strong>1000+ 家</strong>。<br />战略 × AI × 产品，三线合一——把理论变成可落地的经营方案。<br /><br />我的核心理念：<br />⚡ 老板是发动机，定位是方向盘，AI 是放大器<br />⚡ 先改变老板，才能改变企业<br />⚡ 用 AI 锻造你的第二大脑，打造极简组织<br /><br />把公司做小，把影响力做大，把身心做自由。<br /><br />如果你是创业者或企业老板，这里有关于品牌定位、老板 AI 化、商业变现的实战方法论和课程。<br /><strong>期待与你交流。</strong>`}
    withReview={false}
    src="/images/profile/rex1024.png"
    alt="Rex Wang - 王鹏辉"
  />

  <!-- 1.5 Statistics - 数据亮点 -->
  <section class="mx-auto max-w-[85rem] px-4 pt-2 pb-4 sm:px-6 lg:px-8">
    <ul class="grid grid-cols-2 gap-px overflow-hidden rounded-xl bg-neutral-200 dark:bg-neutral-700 md:grid-cols-4">
      {statistics.map((stat) => (
        <li class="bg-white p-6 dark:bg-neutral-800">
          <div class="text-3xl font-bold text-yellow-600 dark:text-yellow-400">{stat.count}</div>
          <div class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">{stat.description}</div>
        </li>
      ))}
    </ul>
  </section>

  <!-- 1.6 Action Buttons -->
  <div class="mx-auto max-w-[85rem] px-4 pb-6 sm:px-6 lg:px-8">
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/about" class="inline-flex items-center gap-2 rounded-full bg-orange-500 px-6 py-3 text-white font-medium hover:bg-orange-600 transition">
        认识我
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
      <a href="/products" class="inline-flex items-center gap-2 rounded-full bg-neutral-700 dark:bg-neutral-600 px-6 py-3 text-white font-medium hover:bg-neutral-800 dark:hover:bg-neutral-500 transition">
        产品
      </a>
      <a href="/podcast" class="inline-flex items-center gap-2 rounded-full border-2 border-neutral-700 dark:border-neutral-500 px-6 py-3 text-neutral-700 dark:text-neutral-300 font-medium hover:bg-neutral-700 hover:text-white dark:hover:bg-neutral-500 dark:hover:text-white transition">
        播客
      </a>
    </div>
  </div>

  <!-- 2. Features - 核心方法论 -->
  <FeaturesGeneral
    title="老板AI化·<span class='text-yellow-500 dark:text-yellow-400'>高维盈利体系</span>"
    subTitle="不是教你用AI工具，而是帮你建立AI时代的商业操作系统。"
    features={features}
  />

  <!-- 3. Testimonials - 客户评价 -->
  <TestimonialsSection
    title="老板们的<span class='text-yellow-500 dark:text-yellow-400'>真实反馈</span>"
    subTitle="先改变老板，才能改变企业。老板脱胎换骨，企业才能脱胎换骨。老板是发动机，定位是方向盘，AI 是放大器。听听已经走过这一步的老板怎么说。"
    testimonials={testimonials}
    imageSrc="/images/events/huichang01.jpg"
    imageAlt="老板AI化实战营课程现场"
  />

  <!-- 4. FAQ -->
  <FAQ title="常见<span class='text-yellow-500 dark:text-yellow-400'>问题</span>" faqs={faqsData} />

  <!-- 5. Bottom CTA -->
  <HeroSectionAlt
    title="先改变老板，才能改变企业"
    subTitle="使命：带领10万+企业老板走进AI世界，用「定位升级 + 老板AI化」跳出同质化内卷，打造极简组织，实现幸福感创业。"
  />
</MainLayout>
