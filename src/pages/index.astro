---
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro';
import FAQ from '@components/sections/misc/FAQ.astro';
import Icon from '@components/ui/icons/Icon.astro';
import { SITE } from '@data/constants';
import features from '@data/features.json';
import faqsData from '@data/faqs.json';

const pageTitle = `${SITE.title} — 老板AI化`;

const testimonials = [
  {
    content: '以前觉得AI跟我这种传统行业老板没关系，上完Rex的课才发现，AI化的第一步真的是换脑子。现在我一个人管着3条业务线，效率比过去一个团队还高。',
    author: '陈总',
    role: '某建材连锁品牌 创始人',
    avatarSrc: '',
  },
  {
    content: '做了15年品牌咨询，换过好几家咨询公司，都是给你一堆PPT自己落地。Rex不一样，他帮你把AI能力直接嵌进执行链路，系统搭好了自己跑。',
    author: '范总',
    role: '某科技企业 CEO',
    avatarSrc: '',
  },
  {
    content: '过去3年公司越做越重，团队60多人还是亏损。上完课后我把80%的重复工作交给了AI，现在15个人的公司利润翻了3倍。Rex让我明白，不是人不够，是认知没到位。',
    author: '林总',
    role: '某消费品品牌 董事长',
    avatarSrc: '',
  },
];

const statistics = [
  { count: '18年', description: '品牌定位咨询实战经验' },
  { count: '1000+场', description: '定位培训授课经历' },
  { count: '1000+家', description: '中小企业服务案例' },
  { count: '10万+', description: '未来实现企业老板AI化目标覆盖' },
];
---

<MainLayout title={pageTitle}>
  <!-- 1. Hero Section -->
  <HeroSection
    title={`Hi，我是 <span class="text-yellow-500 dark:text-yellow-400">Rex Wang</span>`}
    subTitle={`同济EMBA特聘导师 · 品牌定位战略顾问 × AI 商业顾问 · 全球老板AI化课题发起人 &amp; 首席研究员<br /><br />做了 18 年品牌定位，服务过上千家公司。现在只做一件事：<strong class="text-neutral-900 dark:text-white">帮老板用 AI 打造第二大脑</strong>。<br /><br />不是教你用工具，是帮你换个脑子。老板是发动机，定位是方向盘，AI 是放大器——先改变老板，才能改变企业。<br /><br />如果你也想把公司做小、影响力做大、身心做自由，欢迎来我的地盘逛逛。<br /><br /><em>—— Rex</em>`}
    primaryBtn="了解更多"
    primaryBtnURL="/about"
    secondaryBtn="产品与服务"
    secondaryBtnURL="/products"
    withReview={false}
    src="/images/profile/rex1024.png"
    alt="Rex Wang - 王鹏辉"
  />

  <!-- 1.5 Statistics - 数据亮点 -->
  <section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8">
    <ul class="grid grid-cols-2 gap-px overflow-hidden rounded-xl bg-neutral-200 dark:bg-neutral-700 md:grid-cols-4">
      {statistics.map((stat) => (
        <li class="bg-white p-6 dark:bg-neutral-800">
          <div class="text-3xl font-bold text-yellow-600 dark:text-yellow-400">{stat.count}</div>
          <div class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">{stat.description}</div>
        </li>
      ))}
    </ul>
  </section>

  <!-- 2. Features - 核心方法论 -->
  <FeaturesGeneral
    title="老板AI化·<span class='text-yellow-500 dark:text-yellow-400'>高维盈利体系</span>"
    subTitle="不是教你用AI工具，而是帮你建立AI时代的商业操作系统。"
    features={features}
  />

  <!-- 3. Testimonials - 客户评价 -->
  <TestimonialsSection
    title="老板们的<span class='text-yellow-500 dark:text-yellow-400'>真实反馈</span>"
    subTitle="先改变老板，才能改变企业。听听已经走过这一步的老板怎么说。"
    testimonials={testimonials}
  />

  <!-- 4. FAQ -->
  <FAQ title="常见<span class='text-yellow-500 dark:text-yellow-400'>问题</span>" faqs={faqsData} />

  <!-- 5. Bottom CTA -->
  <HeroSectionAlt
    title="先改变老板，才能改变企业"
    subTitle="使命：带领10万+企业老板走进AI世界，用「定位升级 + 老板AI化」跳出同质化内卷，打造极简组织，实现幸福感创业。"
  />
</MainLayout>
