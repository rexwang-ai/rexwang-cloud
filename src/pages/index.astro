---
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro';
import FAQ from '@components/sections/misc/FAQ.astro';
import Icon from '@components/ui/icons/Icon.astro';
import { SITE } from '@data/constants';
import features from '@data/features.json';
import faqsData from '@data/faqs.json';

const pageTitle = `${SITE.title} — 老板AI化`;

const testimonials = [
  {
    content: '以前觉得AI跟我这种传统行业老板没关系，上完Rex的课才发现，AI化的第一步真的是换脑子。现在我一个人管着3条业务线，效率比过去一个团队还高。',
    author: '陈总',
    role: '某建材连锁品牌 创始人',
    avatarSrc: '',
  },
  {
    content: '做了15年品牌咨询，换过好几家咨询公司，都是给你一堆PPT自己落地。Rex不一样，他帮你把AI能力直接嵌进执行链路，系统搭好了自己跑。',
    author: '范总',
    role: '某科技企业 CEO',
    avatarSrc: '',
  },
  {
    content: '过去3年公司越做越重，团队60多人还是亏损。上完课后我把80%的重复工作交给了AI，现在15个人的公司利润翻了3倍。Rex让我明白，不是人不够，是认知没到位。',
    author: '林总',
    role: '某消费品品牌 董事长',
    avatarSrc: '',
  },
];

const statistics = [
  { count: '18年', description: '品牌定位咨询实战经验' },
  { count: '1000+', description: '场定位培训授课经历' },
  { count: '1000+', description: '家中小企业服务案例' },
  { count: '10万+', description: '企业老板AI化目标覆盖' },
];
---

<MainLayout title={pageTitle}>
  <!-- 1. Hero Section -->
  <HeroSection
    title={`<span class="text-sm font-semibold uppercase tracking-wider text-indigo-600 dark:text-indigo-400">老板AI化</span><br />锻造老板<span class="text-yellow-500 dark:text-yellow-400">第二大脑</span><br /><span class="text-lg sm:text-xl font-medium text-neutral-600 dark:text-neutral-300">打造极简组织，实现高维盈利</span>`}
    subTitle={`老板是发动机，定位是方向盘，AI是放大器。<br /><br /><strong>Rex Wang</strong>，全球老板AI化课题发起人 &amp; 首席研究员<br />老板AI化·高维盈利体系创始人<br />18年品牌定位培训咨询经验，帮你用AI构建高维盈利体系。`}
    primaryBtn="了解更多"
    primaryBtnURL="/about"
    secondaryBtn="产品与服务"
    secondaryBtnURL="/products"
    withReview={false}
    src="/images/profile/rex1024.png"
    alt="Rex Wang - 王鹏辉"
  />

  <!-- 2. Features - 核心方法论 -->
  <FeaturesGeneral
    title="老板AI化·<span class='text-yellow-500 dark:text-yellow-400'>高维盈利体系</span>"
    subTitle="不是教你用AI工具，而是帮你建立AI时代的商业操作系统。"
    features={features}
  />

  <!-- 3. Testimonials - 客户评价 -->
  <TestimonialsSection
    title="老板们的<span class='text-yellow-500 dark:text-yellow-400'>真实反馈</span>"
    subTitle="先改变老板，才能改变企业。听听已经走过这一步的老板怎么说。"
    testimonials={testimonials}
    statistics={statistics}
  />

  <!-- 4. FAQ -->
  <FAQ title="常见<span class='text-yellow-500 dark:text-yellow-400'>问题</span>" faqs={faqsData} />

  <!-- 5. Bottom CTA -->
  <HeroSectionAlt
    title="先改变老板，才能改变企业"
    subTitle="使命：带领10万+企业老板走进AI世界，用「定位升级 + 老板AI化」跳出同质化内卷，打造极简组织，实现幸福感创业。"
  />
</MainLayout>
